NODE_ENV=development
PORT=5000

# Supabase → Settings → Database → Connection string → URI
# Password special chars must be URL-encoded (@ → %40, # → %23, / → %2F).
SUPABASE_DB_URL=
DB_SSL=true
# Render / reverse proxy: set to 1 for correct rate-limit IP handling
# TRUST_PROXY=1

# JWT config
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=1d
